{
  "priority": 2,
  "request": {
    "method": "POST",
    "urlPath": "/api/v2/auth/login",
    "bodyPatterns": [
      {
        "matchesJsonPath": "$[?(@.username == 'bad' || @.password == 'bad')]"
      }
    ]
  },
  "response": {
    "status": 422,
    "headers": {
      "Content-Type": "application/json; charset=utf-8"
    },
    "jsonBody": [
      {
        "field": "username",
        "message": "Неверный логин или пароль"
      }
    ]
  }
}
